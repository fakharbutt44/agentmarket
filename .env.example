# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/agentmarket

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Circle API (https://app.circle.com/developer)
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_BASE_URL=https://api-sandbox.circle.com
PLATFORM_WALLET_ID=your_platform_wallet_id

# Arc Blockchain Explorer
ARC_EXPLORER_URL=https://explorer.arc-testnet.io

# Gemini AI (Google AI Studio - free $300 credit)
GEMINI_API_KEY=your_gemini_api_key

# Featherless AI ($25 credit)
FEATHERLESS_API_KEY=your_featherless_api_key

# Agent Pricing (must be <= $0.01 per job)
PRICE_PER_JOB=0.001
MIN_BALANCE=0.05

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
